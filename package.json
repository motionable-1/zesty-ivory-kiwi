{
  "name": "hyperframes-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src && tsc --noEmit",
    "lint:fix": "eslint src --fix && tsc --noEmit",
    "render": "npx --yes --package node@22 --package hyperframes@0.6.65 hyperframes render composition -o renders/output.mp4",
    "doctor": "npx --yes --package node@22 --package hyperframes@0.6.65 hyperframes doctor",
    "fix": "prettier --write src index.html composition/index.html && eslint src --fix && tsc --noEmit"
  },
  "dependencies": {
    "@hyperframes/player": "0.6.65",
    "gsap": "3.15.0"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "prettier": "3.6.0",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.0.7"
  }
}
